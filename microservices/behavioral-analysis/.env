# Release
RELEASE_TAG=latest

# SEAWEEDFS
SEAWEEDFS_ENDPOINT=http://seaweedfs:8333
SEAWEEDFS_BUCKET=behavioral-frames

# VLM
VLM_ENDPOINT=http://ovms-vlm:8001

# MQTT
MQTT_HOST=broker.scenescape.intel.com}
MQTT_PORT=1883

# ---- Behavioral Analysis service ----
BA_SERVICE_PORT=8085
BA_MIN_FRAMES=3        # minimum frames before running pose/VLM analysis
BA_MAX_FRAMES=120      # maximum frames fetched per BA request
BA_POSE_FRAMES=60      # number of frames used for pose scoring
BA_CONFIDENCE=0.5      # keypoint confidence threshold
BA_GST_DEVICE=CPU      # inference device for GStreamer pipeline (CPU / GPU / NPU)
VLM_ENABLED=true
BA_REQUEST_TOPIC=ba/requests 
BA_RESULT_TOPIC=ba/results
DOWNLOADED_MODEL_PATH=../../../models